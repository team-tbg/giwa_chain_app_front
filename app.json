{
  "expo": {
    "name": "나드리",
    "slug": "naduri-app",
    "scheme": "naduri",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F5F7FB",
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "io.giwa.naduri",
      "adaptiveIcon": {
        "backgroundColor": "#0F1613",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "걸은 거리와 동네를 보여드리기 위해 위치를 사용해요."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://api.stg.naduri.app/v1",
      "googleWebClientId": "562062096700-g0fthuqs2fdn8o7aaabesrei5pk2cvki.apps.googleusercontent.com",
      "googleAndroidClientId": "562062096700-ue5dcnii8k3dekga0bo5qoea32nufjfu.apps.googleusercontent.com",
      "googleIosClientId": ""
    }
  }
}
