# 나드리 환경변수 예시 — 이 파일을 복사해 `.env` 로 만들고 값을 채우세요.
#   cp .env.example .env
# EXPO_PUBLIC_* 는 앱 번들에 인라인되는 "공개" 값이라 비밀이 아닙니다.
# (Web 클라이언트 시크릿 등 진짜 비밀은 앱이 아니라 백엔드에 보관)
# 값 변경 후에는 `npx expo start -c` 로 개발 서버를 재시작해야 반영됩니다.

# 백엔드 API base URL
#   실서비스: https://api.stg.naduri.app/v1
#   로컬 목(mock) 서버: http://localhost:3000/v1  (에뮬레이터는 http://10.0.2.2:3000/v1)
EXPO_PUBLIC_API_BASE_URL=

# 구글 OAuth 클라이언트 ID (플랫폼별)
#   웹: id_token 검증 audience + 웹 로그인 (필수)
#   Android: 패키지 io.giwa.naduri + 앱 서명 SHA-1
#   iOS: 번들 ID (iOS 진행 시)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
